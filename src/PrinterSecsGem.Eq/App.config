<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- SECS/HSMS连接配置：Host主动连接本程序时，IpAddress=0.0.0.0、IsActive=false；本程序主动连接Host时，IpAddress填Host地址、IsActive=true。 -->
    <add key="secs4net:IpAddress" value="127.0.0.1" />
    <add key="secs4net:Port" value="5000" />
    <add key="secs4net:DeviceId" value="1" />
    <add key="secs4net:IsActive" value="true" />

    <!-- SECS超时时间，单位毫秒；现场一般不用改。 -->
    <add key="secs4net:T3" value="45000" />
    <add key="secs4net:T5" value="10000" />
    <add key="secs4net:T6" value="5000" />
    <add key="secs4net:T7" value="10000" />
    <add key="secs4net:T8" value="5000" />
    <add key="secs4net:LinkTestInterval" value="60000" />

    <!-- SECS事件和变量ID；Host正式编号确认后再替换。 -->
    <add key="SecsEvents:InitialDataId" value="1" />
    <add key="SecsEvents:ActiveReportsEnabled" value="true" />
    <add key="SecsEvents:ActiveEventReplyExpected" value="false" />
    <add key="SecsEvents:TagReadCeid" value="1001" />
    <add key="SecsEvents:TagReadRptid" value="2001" />
    <add key="SecsEvents:RfidWriteCeid" value="2002" />
    <add key="SecsEvents:RfidWriteRptid" value="2002" />
    <add key="SecsEvents:PrintCompletedCeid" value="2003" />
    <add key="SecsEvents:PrintFailedCeid" value="2004" />
    <add key="SecsEvents:PrintRptid" value="2003" />
    <add key="SecsEvents:ShelfIdVid" value="3001" />
    <add key="SecsEvents:LocationIdVid" value="3002" />
    <add key="SecsEvents:TagVid" value="3003" />
    <add key="SecsEvents:IsLoadedVid" value="3004" />
    <add key="SecsEvents:TimestampVid" value="3005" />

    <!-- RFID/ERack串口硬件配置：PortName按现场COM口修改；DeviceAddress是读写器地址，不是COM口。 -->
    <add key="ERackHardware:Enabled" value="true" />
    <add key="ERackHardware:PortName" value="COM11" />
    <add key="ERackHardware:BaudRate" value="57600" />
    <add key="ERackHardware:DeviceAddress" value="1" />
    <add key="ERackHardware:InventoryMode" value="4" />
    <add key="ERackHardware:InventoryWaitTimeMilliseconds" value="50" />
    <add key="ERackHardware:InventoryWaitCount" value="20" />
    <add key="ERackHardware:KeepPortOpen" value="true" />
    <add key="ERackHardware:WriteTagStartPage" value="1" />
    <add key="ERackHardware:WriteTagWaitTimeMilliseconds" value="200" />
    <add key="ERackHardware:WriteTagWaitCount" value="20" />

    <!-- 本地测试默认值：Content是Test Print/本地写Tag默认内容。 -->
    <add key="LocalValidation:ShelfId" value="SHELF001" />
    <add key="LocalValidation:LocationId" value="LOC001" />
    <add key="LocalValidation:PrinterId" value="PRINTER001" />
    <add key="LocalValidation:Content" value="EFS08IZS" />
    <add key="LocalValidation:Copies" value="1" />

    <!-- 日志配置文件路径。 -->
    <add key="Log4Net:ConfigFile" value="log4net.config" />

    <!-- 状态界面语言：zh-CN=中文，en-US=英文。修改后重启程序生效。 -->
    <add key="StatusUi:Language" value="zh-CN" />

    <!-- 运行模式：Unit=本机ERACK单元；Server=ERACK服务器；Both=同机同时启用。当前服务器TCP方向等客户参考代码确认。 -->
    <add key="Runtime:Mode" value="Unit" />

    <!-- ERACK Server/Unit 自定 TCP JSON Lines 协议。Unit 主动连 Server；Server 按 ShelfId 路由。 -->
    <add key="ERackServer:Enabled" value="true" />
    <add key="ERackServer:ListenIp" value="127.0.0.1" />
    <add key="ERackServer:Port" value="7801" />
    <add key="ERackServer:RequestTimeoutMilliseconds" value="60000" />
    <add key="ERackClient:Enabled" value="false" />
    <add key="ERackClient:ServerHost" value="127.0.0.1" />
    <add key="ERackClient:ServerPort" value="7801" />
    <add key="ERackClient:UnitId" value="UNIT001" />
    <add key="ERackClient:ShelfId" value="SHELF001" />
    <add key="ERackClient:ReconnectDelayMilliseconds" value="3000" />
    <add key="ERackClient:HeartbeatIntervalMilliseconds" value="5000" />

    <!-- ERACK simulation for remote desktop test without MCU/Zebra. Default off. -->
    <add key="ERackSimulation:Enabled" value="false" />
    <add key="ERackSimulation:ShelfId" value="SHELF001" />
    <add key="ERackSimulation:LocationId" value="LOC001" />
    <add key="ERackSimulation:Tag" value="RFID1234567890" />
    <add key="ERackSimulation:StartupDelayMilliseconds" value="3000" />
    <add key="ERackSimulation:StepIntervalMilliseconds" value="5000" />
    <add key="ERackSimulation:Loop" value="true" />

    <!-- LOCATION到MCU一对一映射；没有配置Locations时，程序会回落到上面的ERackHardware默认串口配置。 -->
    <add key="Locations:LOC001:ShelfId" value="SHELF001" />
    <add key="Locations:LOC001:PortName" value="" />
    <add key="Locations:LOC001:BaudRate" value="57600" />
    <add key="Locations:LOC001:DeviceAddress" value="1" />

    <!-- Sensor/display auto workflow is disabled until the customer confirms the sensor rule. -->
    <add key="ERackSensorDisplay:Enabled" value="false" />
    <add key="ERackSensorDisplay:PollIntervalMilliseconds" value="500" />
    <add key="ERackSensorDisplay:SensorCommand" value="5" />
    <add key="ERackSensorDisplay:SensorPayloadIndex" value="1" />
    <add key="ERackSensorDisplay:CheckLevel" value="0" />
    <add key="ERackSensorDisplay:SensorWaitTimeMilliseconds" value="5" />
    <add key="ERackSensorDisplay:SensorWaitCount" value="6" />
    <add key="ERackSensorDisplay:DisplayWaitTimeMilliseconds" value="20" />
    <add key="ERackSensorDisplay:DisplayMinWaitCount" value="5" />
    <add key="ERackSensorDisplay:DisplayMaxBytes" value="512" />
    <add key="ERackSensorDisplay:ReadLengthBytes" value="32" />
    <add key="ERackSensorDisplay:NoIdDisplayText" value="NO ID  " />
    <add key="ERackSensorDisplay:NoIdFailureCode" value="2001" />
    <add key="ERackSensorDisplay:UpdateDisplayOnEveryPoll" value="false" />

    <!-- 打印配置：RealPrintEnabled=false只生成ZPL和日志不出纸；true真实发送到Zebra打印机。 -->
    <add key="Printer:RealPrintEnabled" value="true" />
    <add key="Printer:Mode" value="ZebraCommandLine" />
    <add key="Printer:ZebraCommandLineAssembly" value="zebra-command-line/SdkApi.Desktop.CommandLine.dll" />
    <add key="Printer:ZebraConnectionType" value="Usb" />
    <add key="Printer:ZebraPrinterAddress" value="" />
    <add key="Printer:ZebraPreflightStatusEnabled" value="false" />
    <add key="Printer:ZebraCommandTimeoutMilliseconds" value="10000" />
    <add key="Printer:DotnetExecutable" value="dotnet" />

    <!-- 标签布局配置：203dpi下1mm约等于8点；改完配置必须重启程序后再Test Print。 -->
    <!-- 使用最小兼容ZPL：true更适合现场稳定出纸；false会启用更多纸张/方向控制指令。 -->
    <add key="LabelTemplate:UseMinimalCompatibleCommands" value="false" />
    <!-- 是否重置打印机偏移/方向状态；现场调试阶段建议false。 -->
    <add key="LabelTemplate:ResetPrinterState" value="false" />
    <!-- 标签方向：Normal=横向正常模板；RotateClockwise=顺时针旋转模板。 -->
    <add key="LabelTemplate:Orientation" value="Normal" />
    <!-- Zebra打印方向：N正常，I反向，R旋转，B反向旋转；最小兼容模式下暂不使用。 -->
    <add key="LabelTemplate:PrintOrientation" value="N" />
    <!-- 打印机DPI，仅作记录；当前现场为203。 -->
    <add key="LabelTemplate:Dpi" value="203" />
    <!-- 打印黑度调整：0=不调整；负数变淡，正数变深，建议先试-5或-10。会影响整张标签。 -->
    <add key="LabelTemplate:PrintDarkness" value="0" />
    <!-- 标签宽度点数：2.5英寸 * 203dpi ≈ 508。 -->
    <add key="LabelTemplate:WidthDots" value="480" />
    <!-- 标签高度点数：1.575英寸 * 203dpi ≈ 320。 -->
    <add key="LabelTemplate:HeightDots" value="320" />
    <!-- 是否把标签长度永久应用到介质；现场调试建议false。 -->
    <add key="LabelTemplate:LabelLengthAppliesToAllMedia" value="false" />
    <!-- 顶部偏移，普通模板使用；最小兼容模式下暂不使用。 -->
    <add key="LabelTemplate:LabelTop" value="0" />
    <!-- 左右偏移，普通模板使用；最小兼容模式下暂不使用。 -->
    <add key="LabelTemplate:LabelShift" value="0" />
    <!-- 撕纸位置调整，普通模板使用；最小兼容模式下暂不使用。 -->
    <add key="LabelTemplate:TearOffAdjust" value="0" />
    <!-- 标签原点X，普通模板使用；最小兼容模式下暂不使用。 -->
    <add key="LabelTemplate:LabelHomeX" value="0" />
    <!-- 标签原点Y，普通模板使用；最小兼容模式下暂不使用。 -->
    <add key="LabelTemplate:LabelHomeY" value="0" />
    <!-- 顶部大字X坐标；变大向右，变小向左。 -->
    <add key="LabelTemplate:TopTextX" value="55" />
    <!-- 顶部大字Y坐标；变大向下，变小向上。 -->
    <add key="LabelTemplate:TopTextY" value="35" />
    <!-- 顶部大字统一字号；大于0时会同时作用于字高和字宽，不会把字调扁。 -->
    <add key="LabelTemplate:TopTextSize" value="40" />
    <!-- 顶部大字高度；变大字更高。 -->
    <add key="LabelTemplate:TopTextHeight" value="70" />
    <!-- 顶部大字宽度；变大字更宽/更粗。 -->
    <add key="LabelTemplate:TopTextWidth" value="55" />
    <!-- 顶部大字居中文本框宽度，普通模板使用；最小兼容模式下暂不使用。 -->
    <add key="LabelTemplate:TopTextBlockWidth" value="370" />
    <!-- 一维码X坐标；变大向右。 -->
    <add key="LabelTemplate:BarcodeX" value="75" />
    <!-- 一维码Y坐标；变大向下。 -->
    <add key="LabelTemplate:BarcodeY" value="95" />
    <!-- 一维码模块宽度/粗细；2较细，3较粗更易扫但更宽。 -->
    <add key="LabelTemplate:BarcodeModuleWidth" value="2" />
    <!-- 一维码高度；变大条码更高。 -->
    <add key="LabelTemplate:BarcodeHeight" value="80" />
    <!-- Zebra条码自带小字开关；最小兼容模式下固定关闭，改用下面的自定义小字。 -->
    <add key="LabelTemplate:BarcodeHumanReadable" value="false" />
    <!-- Zebra自带小字是否在条码上方；最小兼容模式下暂不使用。 -->
    <add key="LabelTemplate:BarcodeHumanReadableAbove" value="false" />
    <!-- 条码校验位打印开关；当前内容为字符串，建议false。 -->
    <add key="LabelTemplate:BarcodePrintCheckDigit" value="false" />
    <!-- 自定义条码下方小字开关；true显示，false隐藏。 -->
    <add key="LabelTemplate:BarcodeTextEnabled" value="true" />
    <!-- 自定义条码下方小字X坐标；变大向右。 -->
    <add key="LabelTemplate:BarcodeTextX" value="120" />
    <!-- 自定义条码下方小字Y坐标；变大向下。 -->
    <add key="LabelTemplate:BarcodeTextY" value="190" />
    <!-- 条码下方小字字体：0=默认较黑，A/B通常更细；先试A。 -->
    <add key="LabelTemplate:BarcodeTextFont" value="0" />
    <!-- 条码下方小字渲染方式：ZplFont=打印机内置字体；Bitmap=Windows字体转位图，更接近设计稿细字。 -->
    <add key="LabelTemplate:BarcodeTextRenderMode" value="ZplFont" />
    <!-- Bitmap模式字体名称，建议 Arial。 -->
    <add key="LabelTemplate:BarcodeTextBitmapFontFamily" value="Arial" />
    <!-- Bitmap模式字体像素大小；0表示沿用 BarcodeTextHeight。 -->
    <add key="LabelTemplate:BarcodeTextBitmapFontSize" value="0" />
    <!-- Bitmap模式黑白阈值：越小越细/越淡，建议先试130到160。 -->
    <add key="LabelTemplate:BarcodeTextBitmapThreshold" value="150" />
    <!-- 条码下方小字统一字号；大于0时会同时作用于字高和字宽。 -->
    <add key="LabelTemplate:BarcodeTextSize" value="22" />
    <!-- 自定义条码下方小字高度；变大字更高。 -->
    <add key="LabelTemplate:BarcodeTextHeight" value="38" />
    <!-- 自定义条码下方小字宽度；变大字更宽/更粗。 -->
    <add key="LabelTemplate:BarcodeTextWidth" value="34" />
  </appSettings>
</configuration>
